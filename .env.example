# Required: secret used to sign JWTs. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Gemini API
GEMINI_API_KEY=

# DB — async SQLite for dev; swap to postgres+asyncpg in prod
DATABASE_URL=sqlite+aiosqlite:///./lumina.db

# Where the frontend lives (for CORS + post-OAuth redirect)
FRONTEND_URL=http://localhost:3000

# Token / guest lifetime (days)
JWT_TTL_DAYS=30
GUEST_TTL_DAYS=30
